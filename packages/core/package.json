{
  "name": "@dallay/astro-icon",
  "version": "1.2.4",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./dist/index.js"
    },
    "./components": {
      "types": "./components/index.d.ts",
      "default": "./components/index.ts"
    }
  },
  "files": [
    "index.d.ts",
    "components",
    "dist",
    "typings"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "pnpm run dev"
  },
  "author": {
    "name": "Nate Moore",
    "email": "nate@natemoo.re",
    "url": "https://twitter.com/n_moore"
  },
  "contributors": [
    {
      "name": "dallay",
      "email": "pr@prpr.dev",
      "url": "https://github.com/dallay"
    }
  ],
  "keywords": [
    "astro",
    "astro-integration",
    "astro-component",
    "image",
    "images",
    "icon",
    "icons",
    "iconify",
    "optimization"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dallay/astro-icon.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dallay/astro-icon/issues"
  },
  "homepage": "https://github.com/dallay/astro-icon#readme",
  "dependencies": {
    "@iconify/tools": "^5.0.11",
    "@iconify/types": "^2.0.0",
    "@iconify/utils": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "astro": "^6.1.4",
    "typescript": "^6.0.2",
    "vite": "^7.0.0"
  }
}
